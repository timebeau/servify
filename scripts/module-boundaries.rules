# format:
# handler|Label|file|field_name|contract_expr|constructor_pattern|forbidden_pattern
# runtime|Label|contract_field|contract_expr
# require|file|pattern|message

handler|Agent|apps/server/internal/handlers/agent_handler.go|agentService|agentdelivery\.HandlerService|func NewAgentHandler\(agentService agentdelivery\.HandlerService, logger \*logrus\.Logger\)|\*services\.AgentService
handler|Ticket|apps/server/internal/handlers/ticket_handler.go|ticketService|ticketdelivery\.HandlerService|func NewTicketHandler\(ticketService ticketdelivery\.HandlerService, logger \*logrus\.Logger\)|\*services\.TicketService
handler|Statistics|apps/server/internal/handlers/statistics_handler.go|statsService|analyticsdelivery\.HandlerService|func NewStatisticsHandler\(statsService analyticsdelivery\.HandlerService, logger \*logrus\.Logger\)|\*services\.StatisticsService
handler|Customer|apps/server/internal/handlers/customer_handler.go|customerService|customerdelivery\.HandlerService|func NewCustomerHandler\(customerService customerdelivery\.HandlerService, logger \*logrus\.Logger\)|\*services\.CustomerService
handler|Automation|apps/server/internal/handlers/automation_handler.go|service|automationdelivery\.HandlerService|func NewAutomationHandler\(service automationdelivery\.HandlerService\)|\*services\.AutomationService
handler|Knowledge|apps/server/internal/handlers/knowledge_doc_handler.go|service|knowledgedelivery\.HandlerService|func NewKnowledgeDocHandler\(service knowledgedelivery\.HandlerService\)|\*services\.KnowledgeDocService
handler|Session transfer|apps/server/internal/handlers/session_transfer_handler.go|transferService|routingdelivery\.HandlerService|func NewSessionTransferHandler\(transferService routingdelivery\.HandlerService, logger \*logrus\.Logger\)|\*services\.SessionTransferService
handler|AI|apps/server/internal/handlers/ai_handler.go|aiService|aidelivery\.HandlerService|func NewAIHandler\(aiService aidelivery\.HandlerService\)|aiService services\.AIServiceInterface

runtime|customer handlers|CustomerHandlerService|customerdelivery\.HandlerService
runtime|automation handlers|AutomationHandlerService|automationdelivery\.HandlerService
runtime|knowledge handlers|KnowledgeDocHandler|knowledgedelivery\.HandlerService
runtime|agent handlers|AgentHandlerService|agentdelivery\.HandlerService
runtime|ticket handlers|TicketHandlerService|ticketdelivery\.HandlerService
runtime|statistics handlers|StatisticsHandlerService|analyticsdelivery\.HandlerService
runtime|session transfer handlers|TransferHandlerService|routingdelivery\.HandlerService
runtime|AI handlers|AIHandlerService|aidelivery\.HandlerService

require|apps/server/internal/handlers/health_enhanced.go|aiService aidelivery\.HandlerService|Enhanced health handler must store modules/ai/delivery.HandlerService.
require|apps/server/internal/services/websocket.go|conversationWriter conversationdelivery\.WebSocketMessageWriter|WebSocket hub must store the public conversationdelivery.WebSocketMessageWriter contract.
require|apps/server/internal/services/websocket.go|func \(h \*WebSocketHub\) SetConversationMessageWriter\(writer conversationdelivery\.WebSocketMessageWriter\)|WebSocket hub must accept conversationdelivery.WebSocketMessageWriter.
require|apps/server/internal/app/server/runtime.go|SetConversationMessageWriter\(conversationdelivery\.NewWebSocketMessageAdapter\(conversationService\)\)|Main runtime must wire conversation websocket persistence through the module delivery adapter.
require|apps/server/internal/app/server/realtime_runtime.go|SetConversationMessageWriter\(conversationdelivery\.NewWebSocketMessageAdapter\(conversationService\)\)|Realtime runtime must wire conversation websocket persistence through the module delivery adapter.
require|apps/server/internal/app/server/ai_runtime.go|Service[[:space:]]+aidelivery\.HandlerService|AI assembly must expose the handler-facing AI contract.
require|apps/server/internal/app/server/ai_runtime.go|RuntimeService[[:space:]]+services\.AIServiceInterface|AI assembly must keep a separate runtime AIServiceInterface for non-handler callers.
require|apps/server/internal/app/server/runtime.go|WorkspaceService[[:space:]]+services\.WorkspaceOverviewReader|Runtime must expose workspace via WorkspaceOverviewReader.
require|apps/server/internal/app/server/router.go|WorkspaceService[[:space:]]+services\.WorkspaceOverviewReader|Router dependencies must expose workspace via WorkspaceOverviewReader.
require|apps/server/internal/services/websocket.go|transferService[[:space:]]+SessionTransferRuntime|WebSocket hub must store the session transfer runtime interface.
require|apps/server/internal/services/websocket.go|func \(h \*WebSocketHub\) SetSessionTransferService\(svc SessionTransferRuntime\)|WebSocket hub must accept the session transfer runtime interface.
require|apps/server/internal/handlers/workspace_handler.go|service[[:space:]]+services\.WorkspaceOverviewReader|Workspace handler must store WorkspaceOverviewReader.
require|apps/server/internal/handlers/workspace_handler.go|func NewWorkspaceHandler\(service services\.WorkspaceOverviewReader\)|Workspace handler constructor must accept WorkspaceOverviewReader.
forbid|apps/server/internal/app/server/runtime.go|CustomerService[[:space:]]+\*services\.CustomerService|Runtime must not expose concrete CustomerService.
forbid|apps/server/internal/app/server/runtime.go|AutomationService[[:space:]]+\*services\.AutomationService|Runtime must not expose concrete AutomationService.
forbid|apps/server/internal/app/server/runtime.go|StatisticsService[[:space:]]+\*services\.StatisticsService|Runtime must not expose concrete StatisticsService.
forbid|apps/server/internal/app/server/runtime.go|KnowledgeDocService[[:space:]]+\*services\.KnowledgeDocService|Runtime must not expose concrete KnowledgeDocService.
forbid|apps/server/internal/app/server/runtime.go|TransferService[[:space:]]+\*services\.SessionTransferService|Runtime must not expose concrete SessionTransferService.
forbid|apps/server/internal/app/server/router.go|AutomationService[[:space:]]+\*services\.AutomationService|Router dependencies must not expose concrete AutomationService.
forbid|apps/server/internal/app/server/router.go|TransferService[[:space:]]+\*services\.SessionTransferService|Router dependencies must not expose concrete SessionTransferService.
forbid|apps/server/internal/handlers/workspace_handler.go|service[[:space:]]+\*services\.WorkspaceService|Workspace handler must not depend on concrete WorkspaceService.
forbid|apps/server/internal/services/websocket.go|transferService[[:space:]]+\*SessionTransferService|WebSocket hub must not store concrete SessionTransferService.
